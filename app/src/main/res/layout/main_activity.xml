<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="top">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Введите текст или номер телефона"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/editText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Текст или номер телефона"
        android:inputType="text"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnOpenSecond"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Открыть вторую Activity"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnDial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Позвонить другу"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnShare"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Поделиться текстом" />

</LinearLayout>
